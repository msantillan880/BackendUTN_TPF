            },
            "url": "{{baseUrl}}/api/auth/register"
          },
          "response": [],
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  "const email = `usuario.testing.${Date.now()}@mail.com`;",
                  "pm.collectionVariables.set('testEmail', email);"
                ],
                "type": "text/javascript"
              }
            },
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 201', function () {",
                  "  pm.response.to.have.status(201);",
                  "});",
                  "const json = pm.response.json();",
                  "const data = json && json.data ? json.data : {};",
                  "pm.expect(data).to.have.property('verifyUrlDev');",
                  "if (data.verifyUrlDev) {",
                  "  const match = String(data.verifyUrlDev).match(/[?&]token=([^&#]+)/);",
                  "  if (match && match[1]) pm.collectionVariables.set('testVerifyToken', decodeURIComponent(match[1]));",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
